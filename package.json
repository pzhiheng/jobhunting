{
  "name": "job-hunter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Daily SWE/MLE job finder that fetches from job-board APIs and curates with Claude.",
  "scripts": {
    "configure": "tsx src/configure.ts",
    "fetch": "tsx src/fetch.ts",
    "seed": "tsx src/seed.ts",
    "curate": "tsx src/curate.ts",
    "check-links": "tsx src/check-links.ts",
    "repair-links": "tsx src/repair-links.ts",
    "poll": "tsx src/email-poller.ts",
    "auth-google": "tsx src/auth-google.ts",
    "refine": "tsx src/refine.ts",
    "analyze": "tsx src/analyze.ts",
    "blurbs": "tsx src/company-blurbs.ts",
    "digest": "tsx src/digest.ts",
    "send-digest": "tsx src/send-digest.ts",
    "serve": "tsx src/server.ts",
    "build": "tsc",
    "test": "tsx --test test/unit/*.test.ts test/integration/*.test.ts test/api/*.test.ts",
    "test:e2e": "playwright test",
    "test:all": "npm test && npm run test:e2e"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@libsql/client": "^0.15.15",
    "@types/nodemailer": "^8.0.1",
    "dotenv": "^16.4.7",
    "express": "^5.1.0",
    "imapflow": "^1.4.3",
    "nodemailer": "^9.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
