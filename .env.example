# Anthropic API — required for `configure` (NL → filter)
ANTHROPIC_API_KEY=

# Adzuna job board — free dev key at https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Hosted libSQL (Turso) — optional. If unset, the DB falls back to a local
# file (jobs.db). Set both for the shared hosted database.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Inbox reader (`npm run poll`) — marks jobs applied/OA/interview/offer/rejected
# from your email. Two ways (set JOBHUNTER_MOCK to use the fixture inbox instead):
#  (a) IMAP via app password — SIMPLEST. Reuses SMTP_USER / SMTP_PASS by default,
#      so if those are set there's nothing to add. Override IMAP_USER / IMAP_PASS
#      to read a different mailbox (host/port default to imap.gmail.com:993).
#  (b) Gmail OAuth — create a "Desktop app" OAuth client (console.cloud.google.com
#      → Credentials), then `npm run auth-google` to mint the refresh token.
# IMAP_USER=
# IMAP_PASS=
# POLL_DAYS=30   # how far back the inbox reader looks (default 30; reads All Mail + Trash)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Where the digest email's "Open the tracker" link points (default = local serve).
# TRACKER_URL=http://localhost:3001

# Outbound digest email — `npm run send-digest` emails the digest via SMTP so it
# lands in your inbox (not a draft). SMTP_USER is a Gmail address; SMTP_PASS is a
# Gmail App Password (Google account → Security → 2-Step Verification → App
# passwords). DIGEST_TO is who receives it (defaults to SMTP_USER).
SMTP_USER=
SMTP_PASS=
DIGEST_TO=zp2153@nyu.edu
# Optional overrides (defaults: smtp.gmail.com:465):
# SMTP_HOST=
# SMTP_PORT=
