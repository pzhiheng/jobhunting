# Anthropic API — required for `configure` (NL → filter)
ANTHROPIC_API_KEY=

# Adzuna job board — free dev key at https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Hosted libSQL (Turso) — optional. If unset, the DB falls back to a local
# file (jobs.db). Set both for the shared hosted database.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Gmail (inbound email poller) — OAuth client + refresh token. Required by
# `npm run poll` in real mode (set JOBHUNTER_MOCK to use the fixture inbox).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
