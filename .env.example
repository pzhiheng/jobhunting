# Anthropic API — required for `configure` (NL → filter)
ANTHROPIC_API_KEY=

# Adzuna job board — free dev key at https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Hosted libSQL (Turso) — optional. If unset, the DB falls back to a local
# file (jobs.db). Set both for the shared hosted database.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Gmail (inbound email poller) — OAuth client + refresh token. Required by
# `npm run poll` in real mode (set JOBHUNTER_MOCK to use the fixture inbox).
# Create a "Desktop app" OAuth client (console.cloud.google.com → Credentials)
# for the id/secret, then `npm run auth-google` to mint the refresh token.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=

# Where the digest email's "Open the tracker" link points (default = local serve).
# TRACKER_URL=http://localhost:3001

# Outbound digest email — `npm run send-digest` emails the digest via SMTP so it
# lands in your inbox (not a draft). SMTP_USER is a Gmail address; SMTP_PASS is a
# Gmail App Password (Google account → Security → 2-Step Verification → App
# passwords). DIGEST_TO is who receives it (defaults to SMTP_USER).
SMTP_USER=
SMTP_PASS=
DIGEST_TO=zp2153@nyu.edu
# Optional overrides (defaults: smtp.gmail.com:465):
# SMTP_HOST=
# SMTP_PORT=
